# Copy this file to .env and fill in your values

# Neon connection string — copy from your Neon dashboard
# (Project → Connection Details → Connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Any long random string — used to sign session cookies
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string

PORT=3000

# Optional: Email confirmations (Gmail)
# Use a Gmail App Password — https://myaccount.google.com/apppasswords
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
